{
  "name": "@hypha/adapter-google-drive-folder",
  "version": "0.1.0-dev",
  "description": "Hypha adapter for local folders (mirrors Google Drive exports, supports any directory tree).",
  "type": "module",
  "license": "Apache-2.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": { ".": "./src/index.ts" },
  "hypha": { "adapter": "google-drive-folder" },
  "scripts": { "build": "bun build src/index.ts --outdir dist --target bun", "typecheck": "tsc --noEmit" },
  "dependencies": {
    "@hypha/core": "workspace:*",
    "@hypha/adapter-sdk": "workspace:*",
    "zod": "^3.23.0"
  },
  "devDependencies": { "@hypha/store-sqlite": "workspace:*" }
}
