{
  "name": "@hypha/adapter-gmail-mbox",
  "version": "0.1.0-dev",
  "description": "Hypha adapter for Gmail mbox archives (Google Takeout Mail exports).",
  "type": "module",
  "license": "Apache-2.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": { ".": "./src/index.ts" },
  "hypha": { "adapter": "gmail-mbox" },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hypha/core": "workspace:*",
    "@hypha/adapter-sdk": "workspace:*",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@hypha/store-sqlite": "workspace:*"
  }
}
