{
  "name": "@hypha/inferrer-identity-resolver",
  "version": "0.1.0-dev",
  "description": "Hypha identity-resolver inferrer — three-stage ER cascade (block → score → cluster) over identity.email / identity.handle / identity.display_name nodes.",
  "type": "module",
  "license": "Apache-2.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": { ".": "./src/index.ts" },
  "hypha": { "inferrer": "identity-resolver" },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hypha/core": "workspace:*",
    "@hypha/inferrer-sdk": "workspace:*"
  },
  "devDependencies": {
    "@hypha/store-sqlite": "workspace:*",
    "@hypha/adapter-gmail-mbox": "workspace:*",
    "@hypha/adapter-sdk": "workspace:*"
  }
}
