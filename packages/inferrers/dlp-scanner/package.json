{
  "name": "@hypha/inferrer-dlp-scanner",
  "version": "0.1.0-dev",
  "description": "Hypha DLP / PII scanner. Regex pre-pass for SSN, phone, email, credit-card (Luhn-validated), and common PII kinds. Presidio NER sidecar deferred.",
  "type": "module",
  "license": "Apache-2.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": { ".": "./src/index.ts" },
  "hypha": { "inferrer": "dlp-scanner" },
  "scripts": { "build": "bun build src/index.ts --outdir dist --target bun", "typecheck": "tsc --noEmit" },
  "dependencies": {
    "@hypha/core": "workspace:*",
    "@hypha/inferrer-sdk": "workspace:*"
  },
  "devDependencies": {
    "@hypha/store-sqlite": "workspace:*",
    "@hypha/adapter-sdk": "workspace:*",
    "@hypha/adapter-gmail-mbox": "workspace:*"
  }
}
