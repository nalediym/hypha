{
  "name": "hypha",
  "version": "0.1.0-dev",
  "private": true,
  "description": "Person OS for your static exports — a local-first personal/org knowledge graph library, agent-navigable via MCP.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "nalediym <nalediym@users.noreply.github.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/nalediym/hypha.git"
  },
  "homepage": "https://hypha-gold.vercel.app",
  "keywords": [
    "knowledge-graph",
    "personal-data",
    "mcp",
    "local-first",
    "person-os",
    "agent-memory",
    "bitemporal"
  ],
  "workspaces": [
    "packages/*",
    "packages/adapters/*",
    "packages/inferrers/*",
    "apps/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun test",
    "dev": "bun run --filter '@hypha/server' dev",
    "dev:web": "bun run --filter '@hypha/web' dev",
    "format": "prettier --write .",
    "lint": "bun run typecheck"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "elysia": "^1.4.28"
  }
}
